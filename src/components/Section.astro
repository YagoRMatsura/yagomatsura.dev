---
interface Props {
  id: string;
  title: string;
}
const { id, title } = Astro.props;
---
<section id={id} class="fade-in py-12 sm:py-16">
  <div class="max-w-[880px] mx-auto px-5">
    <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-8">{title}</h2>
    <slot />
  </div>
</section>
